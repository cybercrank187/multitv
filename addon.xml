<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addon id="plugin.video.multitv" name="MultiTV" version="1.0.0" provider-name="MultiTV">
    <extension point="xbmc.python.pluginsource">
        <provides>video</provides>
    </extension>
    <extension point="xbmc.service" library="service.py" start="login"/>
    <extension point="xbmc.addon.metadata">
        <summary lang="de_DE">Einheitliche TV-Plattform mit VIU und Joyn</summary>
        <description lang="de_DE">MultiTV kombiniert die besten Inhalte von VIU und Joyn zu einer einheitlichen TV-Erlebnis. Live-TV, Mediatheken, Serien und Filme - alles an einem Ort.</description>
        <disclaimer lang="de_DE">Dieses Addon verwendet externe APIs und Datenquellen.</disclaimer>
        <language>de</language>
        <platform>all</platform>
        <license>GPL-2.0-only</license>
        <forum>https://github.com</forum>
        <source></source>
        <email></email>
        <assets>
            <icon>resources/icon.png</icon>
            <fanart>resources/fanart.jpg</fanart>
            <banner>resources/banner.png</banner>
        </assets>
        <news></news>
        <requires>
            <import addon="xbmc.python" version="3.11.0"/>
            <import addon="xbmc.addon" version="21.0"/>
            <import addon="script.module.requests" version="2.28.0"/>
        </requires>
    </extension>
</addon>
